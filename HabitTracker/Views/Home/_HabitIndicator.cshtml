@model List<int>

@if (Model != null)
{
    for (int i = 0; i < Model.Count; i++)
    {
        <div class="col">
            @if (Model[i] == 1)
            {
                    <div class="col p-0"><i class="bi bi-circle-fill"></i></div>
            }
            else if (Model[i] == -1)
            {
                <div class="col p-0"><i class="bi bi-circle"></i></div>

            }
            else
            {
                    <div class="col p-0"><i class="bi bi-circle"></i></div>

            }
        </div>
    }
}