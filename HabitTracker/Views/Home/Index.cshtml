@model IEnumerable<HabitTracker.ViewModels.HabitViewModel>
@{
    ViewData["Title"] = "Home Page";
}

<partial name="_HabitList" model="Model" />

<script>
    document.querySelectorAll("input.habit-checker").forEach(el => {
        el.addEventListener("click", async () => {

            const habitId = el.getAttribute("data-id");

            try {
                const res = await fetch(`/habit/MarkAsCompleted/${habitId}`);
                const data = await res.text();
                debugger;
                if (data === "true") {
                    el.checked = true;
                    await refreshHabitIndicators(habitId);
                } else {
                    alert("Failed to mark habit as done.");
                    el.checked = false;
                }

            } catch (err) {
                alert("Error marking habit as done.");
                el.checked = false;
                 console.error(err);
            }
        });
    });

    function refreshHabitIndicators(id) {
        fetch(`/home/habitIndicator/${id}`).then(res => res.text()).then(html => {
            document.querySelector(`#habit-indicator-${id}`).innerHTML = html;
        });
    }
</script>